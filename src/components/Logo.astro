---
export interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<svg
  viewBox="0 0 100 100"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  class={className}
>
  <defs>
    <linearGradient id="tenz-gradient" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#2091D0" />
      <stop offset="100%" stop-color="#125a88" />
    </linearGradient>
  </defs>
  <rect width="100" height="100" rx="24" fill="url(#tenz-gradient)" />
  <path
    d="M32 68L52 32L72 68"
    stroke="white"
    stroke-width="10"
    stroke-linecap="round"
    stroke-linejoin="round"
  />
</svg>

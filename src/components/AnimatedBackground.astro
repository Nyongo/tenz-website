---
// Subtle animated background with soft blobs and grid texture.
---

<div class="pointer-events-none absolute inset-0 overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-br from-brand via-brand-2 to-brand opacity-90" />

  <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(77,184,232,0.22),transparent_55%)]" />
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_bottom,rgba(32,145,208,0.12),transparent_60%)]" />

  <div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(32,145,208,0.04) 1px,transparent 1px),linear-gradient(rgba(32,145,208,0.04) 1px,transparent 1px)] bg-[length:70px_70px]" />

  <div class="absolute left-1/2 top-0 -z-10 h-[540px] w-[780px] -translate-x-1/2 -translate-y-1/3 opacity-40 blur-3xl">
    <div class="relative h-full w-full">
      <div class="absolute inset-0 rounded-full bg-gradient-to-br from-teal-400/50 via-teal-500/30 to-amber-500/15 opacity-90 animate-blob" />
      <div class="absolute -left-24 top-20 h-64 w-64 rounded-full bg-teal-300/20 blur-2xl animate-blob" />
      <div class="absolute right-10 top-32 h-72 w-72 rounded-full bg-amber-400/20 blur-2xl animate-blob" />
    </div>
  </div>
</div>

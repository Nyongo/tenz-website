---
import Layout from '../layouts/Layout.astro';

const services = [
  {
    number: '01',
    title: 'Digital Banking Products',
    desc: 'Modern channels for banks and financial institutions to serve customers seamlessly.',
    items: [
      'Mobile Banking',
      'Internet Banking',
      'Agency Banking',
      'WhatsApp Banking',
      'Payments Gateways',
    ],
  },
  {
    number: '02',
    title: 'VAS Services',
    desc: 'High-availability communication and engagement tools for enterprise operations.',
    items: [
      'Bulk SMS',
      'USSD Solutions',
      'Bulk Email Solution',
      'Airtime & Data Distribution',
      'Chatbots',
      'Social Media Integration',
    ],
  },
  {
    number: '03',
    title: 'Custom Solutions',
    desc: 'Domain-specific platforms designed around your workflows and business model.',
    items: [
      'Automated Reconciliation Solution',
      'Digital Loan Origination & Management',
      'Agent Network Management',
      'Digital Cash Management & Distribution',
      'Automated Leasing Solution',
      'Finance & Accounting Module',
      'Payroll and HR Solution',
    ],
  },
  {
    number: '04',
    title: 'Technology Services',
    desc: 'Advisory and engineering support from planning through post-go-live.',
    items: [
      'Website Development',
      'Technology Consulting',
      'Mobile App Development',
      'Custom Solution Development',
      'Hosting',
      'Technical Support',
    ],
  },
];

const solutions = [
  {
    badge: 'FINANCIAL',
    title: 'Automated Reconciliation',
    desc: 'Automated matching and exception tracking for accurate, faster financial operations.',
  },
  {
    badge: 'COMMUNICATIONS',
    title: 'BulkSMS Platform',
    desc: 'High-throughput enterprise messaging for alerts, campaigns, and operational communication.',
  },
  {
    badge: 'LENDING',
    title: 'Loan Origination & Management',
    desc: 'End-to-end digital lending journey from onboarding and scoring to disbursement and collections.',
  },
  {
    badge: 'AGENT NETWORK',
    title: 'Agent Management Platform',
    desc: 'Onboarding, monitoring, settlement, and performance visibility for distributed agent channels.',
  },
  {
    badge: 'DIGITAL BANKING',
    title: 'Omnichannel Banking',
    desc: 'Mobile, internet, agency, and WhatsApp banking experiences connected to your core operations.',
  },
];

const whyPoints = [
  {
    number: '01',
    title: 'One-stop technology partner',
    text: 'Advisory, product engineering, and support delivered by a coordinated client service team.',
  },
  {
    number: '02',
    title: 'Proven multi-disciplinary team',
    text: 'A team with business and technical focus experienced in multi-location, multi-disciplinary engagements.',
  },
  {
    number: '03',
    title: 'Regional market understanding',
    text: 'Built in Nairobi for East and Central African realities with mobile-first and digitization-first delivery.',
  },
  {
    number: '04',
    title: 'Continuous improvement culture',
    text: 'We operate with continuous learning, research, and optimization to sustain client growth over time.',
  },
];
---

<Layout title="Tenz Technologies" description="Mission-critical technology solutions provider in East and Central Africa.">
  <section id="hero">
    <div class="hero-bg"></div>
    <div class="hero-grid"></div>
    <div class="hero-grain"></div>

    <div class="hero-content">
      <div class="hero-eyebrow"><span>MISSION-CRITICAL TECHNOLOGY SOLUTIONS</span></div>
      <h1 class="hero-h1">
        Tenz<br />
        <span class="line2">Technologies.</span>
      </h1>
      <p class="hero-tagline">Our mission is to increase efficiency through technology.</p>
      <p class="hero-desc">
        Founded in 2020 in Nairobi, Tenz Technologies delivers reliable, secure, and modern information solutions across finance, insurance, health, and retail.
      </p>
      <div class="hero-actions">
        <button class="btn-primary" onclick="document.getElementById('services').scrollIntoView({behavior:'smooth'})">
          EXPLORE SERVICES
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </button>
        <button class="btn-ghost" onclick="document.getElementById('contact').scrollIntoView({behavior:'smooth'})">TALK TO OUR TEAM</button>
      </div>
    </div>

    <div class="hero-mark">
      <svg viewBox="0 0 400 400" fill="none" xmlns="http://www.w3.org/2000/svg">
        <polygon points="200,20 370,110 370,290 200,380 30,290 30,110" fill="rgba(6,36,32,0.6)" stroke="#14D4B8" stroke-width="2"/>
        <polygon points="200,10 380,107 380,293 200,390 20,293 20,107" fill="none" stroke="#14B8A0" stroke-width="0.8" opacity="0.3"/>
        <polygon points="200,40 350,122 350,278 200,360 50,278 50,122" fill="none" stroke="#14B8A0" stroke-width="0.5" opacity="0.15"/>
        <path d="M120,160 L180,110 L220,110 L280,160 L280,210 L220,240 L180,240 L120,272 L120,310 L180,350 L280,295" fill="none" stroke="white" stroke-width="18" stroke-linecap="round" stroke-linejoin="round"/>
        <circle cx="200" cy="110" r="18" fill="#14D4B8"/>
        <circle cx="200" cy="240" r="18" fill="#14D4B8"/>
        <circle cx="280" cy="210" r="12" fill="#14B8A0" opacity="0.8"/>
        <circle cx="120" cy="272" r="12" fill="#14B8A0" opacity="0.6"/>
      </svg>
    </div>

    <div class="hero-stats">
      <div class="stat"><div class="num">2020</div><div class="label">ESTABLISHED</div></div>
      <div class="stat"><div class="num">5+</div><div class="label">CORE INDUSTRIES</div></div>
      <div class="stat"><div class="num">24/7</div><div class="label">DIGITAL EXPERIENCE</div></div>
      <div class="stat"><div class="num">ECA</div><div class="label">REGIONAL FOCUS</div></div>
    </div>
  </section>

  <div class="marquee-strip">
    <div class="marquee-inner">
      {['DIGITAL BANKING', 'MOBILE BANKING', 'INTERNET BANKING', 'WHATSAPP BANKING', 'PAYMENTS GATEWAYS', 'BULK SMS', 'USSD SOLUTIONS', 'TECH CONSULTING'].map((item) => (
        <span class="marquee-item">{item}</span>
      ))}
      {['DIGITAL BANKING', 'MOBILE BANKING', 'INTERNET BANKING', 'WHATSAPP BANKING', 'PAYMENTS GATEWAYS', 'BULK SMS', 'USSD SOLUTIONS', 'TECH CONSULTING'].map((item) => (
        <span class="marquee-item">{item}</span>
      ))}
    </div>
  </div>

  <section id="services" class="section">
    <div class="section-inner">
      <div class="s-label reveal">02 &nbsp; PRODUCTS &amp; SERVICES</div>
      <h2 class="s-title reveal reveal-delay-1">
        Digital products built for <em>growth</em>
      </h2>
      <p class="s-sub reveal reveal-delay-2">
        We combine digital banking products, VAS, and custom enterprise solutions to accelerate business digitization.
      </p>

      <div class="services-grid reveal reveal-delay-1">
        {services.map((service) => (
          <div class="service-card">
            <div class="sc-num">{service.number}</div>
            <div class="sc-title">{service.title}</div>
            <div class="sc-desc">{service.desc}</div>
            <ul class="sc-items">
              {service.items.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="project-management" class="section">
    <div class="section-inner">
      <div class="s-label reveal">05 &nbsp; DELIVERY APPROACH</div>
      <h2 class="s-title reveal reveal-delay-1">
        Execution that stays <em>on track</em>
      </h2>
      <p class="s-sub reveal reveal-delay-2">
        Our project model aligns with a practical 6-phase plan: requirements, design, development, quality assurance, deployment, and training.
      </p>

      <div class="pm-layout reveal reveal-delay-1">
        <div class="pm-text">
          <div class="pm-steps">
            <div class="pm-step reveal reveal-delay-1">
              <div class="pm-num">01</div>
              <div class="pm-body">
                <div class="pm-title">Requirements gathering</div>
                <div class="pm-text">Engage stakeholders and document functional and non-functional requirements.</div>
              </div>
            </div>
            <div class="pm-step reveal reveal-delay-2">
              <div class="pm-num">02</div>
              <div class="pm-body">
                <div class="pm-title">System design and development</div>
                <div class="pm-text">Create architecture and wireframes, then build all website and platform modules.</div>
              </div>
            </div>
            <div class="pm-step reveal reveal-delay-3">
              <div class="pm-num">03</div>
              <div class="pm-body">
                <div class="pm-title">Quality assurance & security</div>
                <div class="pm-text">Run functional, performance, and security validation before release.</div>
              </div>
            </div>
            <div class="pm-step reveal reveal-delay-4">
              <div class="pm-num">04</div>
              <div class="pm-body">
                <div class="pm-title">Deployment & training</div>
                <div class="pm-text">Go live, configure environments, and train administrators and end users.</div>
              </div>
            </div>
          </div>
        </div>

        <div class="pm-visual">
          <div class="pm-card">
            <div class="pm-card-top">
              <div class="pm-card-kicker">PROJECT PLAN</div>
              <div class="pm-card-title">21-day delivery cycle</div>
            </div>

            <div class="pm-bullets">
              <div class="pm-bullet">
                <span class="pm-dot" aria-hidden="true" />
                Mobile-first user experience
              </div>
              <div class="pm-bullet">
                <span class="pm-dot" aria-hidden="true" />
                Security-first implementation
              </div>
              <div class="pm-bullet">
                <span class="pm-dot" aria-hidden="true" />
                Handover with training support
              </div>
            </div>

            <div class="pm-card-foot">
              Need a proposal?{" "}
              <a class="pm-cta" href="#contact">Start a project</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="solutions" class="section">
    <div class="section-inner">
      <div class="s-label reveal">03 &nbsp; SOLUTION PORTFOLIO</div>
      <h2 class="s-title reveal reveal-delay-1">
        Enterprise-ready <em>Solutions</em>
      </h2>
      <p class="s-sub reveal reveal-delay-2">
        Purpose-built platforms for digital banking, customer engagement, and financial operations.
      </p>

      <div class="solutions-grid">
        {solutions.map((solution, idx) => (
          <div class="sol-card reveal reveal-delay-{Math.min(idx + 1, 3)}">
            <span class="sol-badge">{solution.badge}</span>
            <div class="sol-title">{solution.title}</div>
            <div class="sol-desc">{solution.desc}</div>
            <div class="sol-link">
              LEARN MORE
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M3 8h10M9 4l4 4-4 4" stroke="#14D4B8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </div>
          </div>
        ))}
        <div class="sol-card reveal reveal-delay-3" style="border-style:dashed;display:flex;flex-direction:column;justify-content:center;align-items:center;text-align:center;background:rgba(20,184,160,0.02)">
          <div style="font-size:36px;color:var(--t400);margin-bottom:16px">+</div>
          <div class="sol-title" style="font-size:16px">Custom Solution</div>
          <div class="sol-desc">Don't see what you need? We build bespoke software tailored precisely to your organisation's requirements.</div>
          <div class="sol-link" style="justify-content:center">
            TALK TO US
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="#14D4B8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="why" class="section">
    <div class="section-inner">
      <div class="why-layout">
        <div>
          <div class="s-label reveal">04 &nbsp; WHY TENZ</div>
          <h2 class="s-title reveal reveal-delay-1">
            Reliable, secure,<br />
            <em>and modern solutions.</em>
          </h2>
          <p class="s-sub reveal reveal-delay-2" style="margin-bottom:40px">
            We bring business and technical depth, proven multi-disciplinary delivery, and one-stop advisory services.
          </p>

          <div class="why-points">
            {whyPoints.map((point, idx) => (
              <div class={`why-point reveal reveal-delay-${idx + 1}`}>
                <div class="wp-num">{point.number}</div>
                <div class="wp-body">
                  <div class="wp-title">{point.title}</div>
                  <div class="wp-text">{point.text}</div>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="why-visual reveal reveal-delay-2">
          <div class="why-hex-cluster">
            <svg viewBox="0 0 400 400" fill="none" xmlns="http://www.w3.org/2000/svg">
              <polygon points="200,60 290,110 290,210 200,260 110,210 110,110" fill="rgba(6,36,32,0.8)" stroke="#14D4B8" stroke-width="1.5"/>
              <path d="M165,148 L187,128 L213,128 L235,148 L235,168 L213,178 L187,178 L165,190 L165,200 L187,215 L235,200" fill="none" stroke="white" stroke-width="7" stroke-linecap="round" stroke-linejoin="round"/>
              <circle cx="200" cy="128" r="7" fill="#14D4B8"/>
              <circle cx="200" cy="178" r="7" fill="#14D4B8"/>
              <polygon points="200,10 228,26 228,58 200,74 172,58 172,26" fill="rgba(6,36,32,0.5)" stroke="#14B8A0" stroke-width="1" opacity="0.7"/>
              <text x="200" y="46" text-anchor="middle" font-family="Barlow,sans-serif" font-size="9" font-weight="500" fill="#14D4B8" letter-spacing="0">DEV</text>
              <polygon points="320,100 348,116 348,148 320,164 292,148 292,116" fill="rgba(6,36,32,0.5)" stroke="#14B8A0" stroke-width="1" opacity="0.7"/>
              <text x="320" y="136" text-anchor="middle" font-family="Barlow,sans-serif" font-size="8" font-weight="500" fill="#14D4B8">CLOUD</text>
              <polygon points="320,240 348,256 348,288 320,304 292,288 292,256" fill="rgba(6,36,32,0.5)" stroke="#14B8A0" stroke-width="1" opacity="0.7"/>
              <text x="320" y="276" text-anchor="middle" font-family="Barlow,sans-serif" font-size="9" font-weight="500" fill="#14D4B8">DATA</text>
              <polygon points="200,310 228,326 228,358 200,374 172,358 172,326" fill="rgba(6,36,32,0.5)" stroke="#14B8A0" stroke-width="1" opacity="0.7"/>
              <text x="200" y="346" text-anchor="middle" font-family="Barlow,sans-serif" font-size="9" font-weight="500" fill="#14D4B8">PM</text>
              <polygon points="80,240 108,256 108,288 80,304 52,288 52,256" fill="rgba(6,36,32,0.5)" stroke="#14B8A0" stroke-width="1" opacity="0.7"/>
              <text x="80" y="276" text-anchor="middle" font-family="Barlow,sans-serif" font-size="8" font-weight="500" fill="#14D4B8">WRITE</text>
              <polygon points="80,100 108,116 108,148 80,164 52,148 52,116" fill="rgba(6,36,32,0.5)" stroke="#14B8A0" stroke-width="1" opacity="0.7"/>
              <text x="80" y="136" text-anchor="middle" font-family="Barlow,sans-serif" font-size="9" font-weight="500" fill="#14D4B8">OPS</text>
              <line x1="200" y1="74" x2="200" y2="108" stroke="#14B8A0" stroke-width="0.8" stroke-dasharray="3 3" opacity="0.4"/>
              <line x1="290" y1="140" x2="292" y2="140" stroke="#14B8A0" stroke-width="0.8" stroke-dasharray="3 3" opacity="0.4"/>
              <line x1="290" y1="200" x2="292" y2="272" stroke="#14B8A0" stroke-width="0.8" stroke-dasharray="3 3" opacity="0.4"/>
              <line x1="200" y1="260" x2="200" y2="310" stroke="#14B8A0" stroke-width="0.8" stroke-dasharray="3 3" opacity="0.4"/>
              <line x1="110" y1="200" x2="108" y2="272" stroke="#14B8A0" stroke-width="0.8" stroke-dasharray="3 3" opacity="0.4"/>
              <line x1="110" y1="140" x2="108" y2="140" stroke="#14B8A0" stroke-width="0.8" stroke-dasharray="3 3" opacity="0.4"/>
            </svg>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="about" class="section">
    <div class="section-inner">
      <div class="about-layout">
        <div class="about-text">
          <div class="s-label reveal">06 &nbsp; ABOUT TENZ</div>
          <p class="big-q reveal reveal-delay-1">
            "Our vision is to be a market leader in reliable, secure, and modern information technology solutions in Eastern and Central Africa."
          </p>
          <p class="reveal reveal-delay-2">
            Tenz Technologies was founded in 2020 and has grown from digitization services in Kenya's financial sector into a broader technology partner for banking, insurance, health, and retail.
          </p>
          <p class="reveal reveal-delay-3">
            Our objective is simple: help clients succeed sustainably through systems integration, mobile apps, digital banking solutions, VAS, and fintech services.
          </p>
          <div class="about-values reveal reveal-delay-2">
            <div class="av-item">
              <div class="av-title">VISION</div>
              <div class="av-text">Be a market leader in modern technology solutions across Eastern and Central Africa.</div>
            </div>
            <div class="av-item">
              <div class="av-title">MISSION</div>
              <div class="av-text">Increase efficiency through technology.</div>
            </div>
            <div class="av-item">
              <div class="av-title">COMMITMENT</div>
              <div class="av-text">Continuous learning, research, and improvement in every engagement.</div>
            </div>
            <div class="av-item">
              <div class="av-title">VALUE PROPOSITION</div>
              <div class="av-text">One-stop advisory and technology services from a business-and-technical team.</div>
            </div>
          </div>
        </div>
        <div class="about-img-wrap reveal reveal-delay-3">
          <div class="about-card">
            <div class="big-stat">2020</div>
            <div class="big-label">YEAR FOUNDED</div>
            <div class="about-founders">
              <div class="founder">
                <div class="founder-avatar">20</div>
                <div class="founder-info">
                  <div class="f-name">Establishment</div>
                  <div class="f-role">Started with digitization services in Kenya's financial industry.</div>
                </div>
              </div>
              <div class="founder">
                <div class="founder-avatar">24</div>
                <div class="founder-info">
                  <div class="f-name">Go-to-market</div>
                  <div class="f-role">Actively selling and scaling products across sectors.</div>
                </div>
              </div>
            </div>
            <div style="margin-top:28px;padding-top:20px;border-top:1px solid rgba(20,184,160,0.1)">
              <div style="font-family:var(--serif);font-style:italic;font-size:16px;color:var(--t300);opacity:0.7;line-height:1.6">
                Increase efficiency<br />through technology.
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="contact" class="section">
    <div class="section-inner">
      <div class="s-label reveal">07 &nbsp; GET IN TOUCH</div>
      <h2 class="s-title reveal reveal-delay-1">Let's digitize <em>your</em> business.</h2>
      <p class="s-sub reveal reveal-delay-2">
        Tell us your goals and we will propose the right digital banking, VAS, or custom solution path.
      </p>
      <div class="contact-layout">
        <div class="contact-info reveal reveal-delay-1">
          <div class="ci-item">
            <div class="ci-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5S10.62 6.5 12 6.5s2.5 1.12 2.5 2.5S13.38 11.5 12 11.5z" fill="currentColor" />
              </svg>
            </div>
            <div>
              <div class="ci-label">LOCATION</div>
              <div class="ci-value">Nairobi, Kenya</div>
            </div>
          </div>
          <div class="ci-item">
            <div class="ci-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                <path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z" fill="currentColor" />
              </svg>
            </div>
            <div>
              <div class="ci-label">EMAIL</div>
              <div class="ci-value">info@tenztechnologies.com</div>
            </div>
          </div>
          <div class="ci-item">
            <div class="ci-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z" fill="currentColor" />
              </svg>
            </div>
            <div>
              <div class="ci-label">PHONE</div>
              <div class="ci-value">+254 (0) 700 000 000</div>
            </div>
          </div>
          <div class="ci-item">
            <div class="ci-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" fill="currentColor" />
              </svg>
            </div>
            <div>
              <div class="ci-label">AVAILABILITY</div>
              <div class="ci-value">Mon – Fri, 8am – 6pm EAT</div>
            </div>
          </div>
          <div style="margin-top:40px;padding:28px;background:rgba(20,184,160,0.05);border:1px solid rgba(20,184,160,0.1);border-radius:8px">
            <p style="font-family:var(--serif);font-style:italic;font-size:20px;color:var(--t300);line-height:1.5">
              "Our focus is to elevate business productivity through technology."
            </p>
            <p style="font-size:11px;letter-spacing:2px;color:rgba(20,184,160,0.35);margin-top:12px">— TENZ TECHNOLOGIES</p>
          </div>
        </div>

        <div class="contact-form reveal reveal-delay-2">
          <div class="form-row">
            <div class="field">
              <label>FIRST NAME</label>
              <input type="text" placeholder="John" />
            </div>
            <div class="field">
              <label>LAST NAME</label>
              <input type="text" placeholder="Doe" />
            </div>
          </div>
          <div class="field">
            <label>EMAIL ADDRESS</label>
            <input type="email" placeholder="john@company.com" />
          </div>
          <div class="field">
            <label>ORGANISATION</label>
            <input type="text" placeholder="Your company or institution" />
          </div>
          <div class="field">
            <label>SERVICE OF INTEREST</label>
            <select>
              <option value="" disabled selected>Select a service...</option>
              <option>Software &amp; Web Development</option>
              <option>Technical Consulting</option>

---
import Layout from '../../layouts/Layout.astro';

export function getStaticPaths() {
  const modules = import.meta.glob('../../content/blog/*.md', { eager: true });
  return Object.keys(modules).map((filePath) => {
    const slug = filePath.split('/').pop()?.replace(/\.md$/, '') ?? '';
    return { params: { slug } };
  });
}

const modules = import.meta.glob('../../content/blog/*.md', { eager: true });
const { slug } = Astro.params;
const post = Object.entries(modules)
  .map(([filePath, module]: [string, any]) => ({
    slug: filePath.split('/').pop()?.replace(/\.md$/, '') ?? '',
    ...module,
  }))
  .find((p) => p.slug === slug);

if (!post) {
  throw new Error(`Blog post not found: ${slug}`);
}
---

<Layout title={`${post.frontmatter.title} — Tenz Technologies`} description={post.frontmatter.description}>
  <article class="prose prose-slate max-w-none dark:prose-invert">
    <header class="mb-10">
      <p class="text-sm font-semibold uppercase tracking-wide text-indigo-600 dark:text-indigo-300">{new Date(post.frontmatter.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
      <h1 class="mt-2 text-3xl font-semibold text-slate-900 dark:text-white">{post.frontmatter.title}</h1>
    </header>

    <div class="prose prose-slate dark:prose-invert">
      <post.Content />
    </div>
  </article>
</Layout>

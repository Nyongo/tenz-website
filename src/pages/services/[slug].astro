---
import Layout from '../../layouts/Layout.astro';
import { serviceCategories } from '../../data/services';

export function getStaticPaths() {
  return serviceCategories.flatMap((category) =>
    category.items.map((service) => ({ params: { slug: service.slug } }))
  );
}

const { slug } = Astro.params;
const allServices = serviceCategories.flatMap((category) =>
  category.items.map((service) => ({
    ...service,
    categoryTitle: category.title,
    categorySlug: category.slug,
  }))
);

const service = allServices.find((item) => item.slug === slug);

if (!service) {
  throw new Error(`Service not found: ${slug}`);
}
---

<Layout title={`${service.title} — Tenz Technologies`} description={service.description}>
  <article class="space-y-10 animate-fade-in">
    <header class="grid gap-6 md:grid-cols-[340px_1fr] md:items-start">
      <div class="rounded-2xl border border-slate-200 bg-white/60 p-6 shadow-sm backdrop-blur dark:border-slate-800 dark:bg-slate-950/40">
        <img
          src={service.image ?? '/images/services/placeholder.svg'}
          alt=""
          class="h-56 w-full rounded-xl object-cover"
        />
        <div class="mt-5 space-y-3">
          <p class="text-xs font-semibold uppercase tracking-wide text-indigo-600 dark:text-indigo-300">{service.categoryTitle}</p>
          <h1 class="text-3xl font-semibold tracking-tight text-slate-900 dark:text-white">{service.title}</h1>
          {service.description ? (
            <p class="text-sm text-slate-600 dark:text-slate-300">{service.description}</p>
          ) : null}
        </div>
      </div>

      <div class="space-y-8">
        <div class="rounded-2xl border border-slate-200 bg-white/60 p-6 shadow-sm backdrop-blur dark:border-slate-800 dark:bg-slate-950/40">
          <h2 class="text-lg font-semibold text-slate-900 dark:text-white">What to expect</h2>
          <ul class="mt-4 space-y-3 text-sm text-slate-700 dark:text-slate-200">
            <li class="flex gap-3">
              <span class="mt-1 h-2 w-2 rounded-full bg-indigo-500" aria-hidden="true" />
              Collaborative kickoff with clear success criteria.
            </li>
            <li class="flex gap-3">
              <span class="mt-1 h-2 w-2 rounded-full bg-indigo-500" aria-hidden="true" />
              Regular progress updates and rapid feedback loops.
            </li>
            <li class="flex gap-3">
              <span class="mt-1 h-2 w-2 rounded-full bg-indigo-500" aria-hidden="true" />
              Written recommendations and next-step guidance.
            </li>
          </ul>
        </div>

        <div class="rounded-2xl border border-slate-200 bg-white/60 p-6 shadow-sm backdrop-blur dark:border-slate-800 dark:bg-slate-950/40">
          <h2 class="text-lg font-semibold text-slate-900 dark:text-white">Next steps</h2>
          <div class="mt-4 flex flex-col gap-3 sm:flex-row">
            <a
              href="/services"
              class="inline-flex items-center justify-center rounded-full border border-slate-200 bg-white px-6 py-3 text-sm font-semibold text-slate-800 shadow-sm hover:bg-slate-50 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-100 dark:hover:bg-slate-800"
              >Back to services</a
            >
            <a
              href='/contact'
              class="inline-flex items-center justify-center rounded-full bg-indigo-600 px-6 py-3 text-sm font-semibold text-white shadow hover:bg-indigo-500"
              >Contact us about this</a
            >
          </div>
        </div>
      </div>
    </header>

    <section class="prose prose-slate max-w-none dark:prose-invert">
      <h2 class="text-xl font-semibold">How we deliver</h2>
      <p>
        Every engagement starts with discovery, followed by a shared plan that keeps the work aligned with your highest priorities. We keep documentation lean and ensure decisions translate into code and process changes.
      </p>
      <p>
        If you already know your goals, we can go straight to an implementation plan. If you need more definition, we can begin with a short scoping phase to define clear outcomes.
      </p>
      <blockquote>
        <p>
          “We don’t just hand over a report—we deliver a path forward and ensure your team can run with it.”
        </p>
      </blockquote>
    </section>
  </article>
</Layout>
